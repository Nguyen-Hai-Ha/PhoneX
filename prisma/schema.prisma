// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model Product {
  id          Int           @id @default(autoincrement())
  name        String
  slug        String        @unique
  description String?       @db.VarChar(1000)
  content     String?       @db.VarChar(5000)
  image_url   String?
  brand       String
  status      ProductStatus @default(ACTIVE)
  created_at   DateTime      @default(now())
  updated_at   DateTime      @updatedAt

  categoryId Int
  category   Category @relation(fields: [categoryId], references: [id])

  tags        Tags[]
  images      Image[]
  wishlists   Wishlist[]
  questions   ProductQuestion[]
  reviews     ProductReview[]
  variants    ProductVariant[]

  @@map("product")
}

model Category {
  id        Int      @id @default(autoincrement())
  name      String
  slug      String   @unique
  image_url String?
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  products Product[]

  @@map("category")
}

model Tags {
  id        Int      @id @default(autoincrement())
  name      String
  slug      String   @unique
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  products Product[]

  @@map("tags")
}

model Image {
  id        Int      @id @default(autoincrement())
  url       String
  alt       String
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  productId Int
  product   Product @relation(fields: [productId], references: [id])

  @@map("image")
}

model Wishlist {
  id        Int      @id @default(autoincrement())
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  productId Int
  product   Product @relation(fields: [productId], references: [id])

  userId Int
  user   User @relation(fields: [userId], references: [id])

  @@map("wishlist")
}

model User {
  id        Int      @id @default(autoincrement())
  name      String
  email     String   @unique
  password  String
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  roleId Int
  role   Role @relation(fields: [roleId], references: [id])

  wishlists    Wishlist[]
  orders        Order[]
  answers      ProductAnswer[]
  reviews      ProductReview[]
  questions    ProductQuestion[]

  @@map("user")
}

model Role {
  id        Int      @id @default(autoincrement())
  name      String
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  users User[]

  @@map("role")
}

model ProductVariant {
  id        Int     @id @default(autoincrement())
  storage   String  
  color     String  
  condition String?  
  price     Decimal @db.Decimal(12, 2) 
  stock     Int     @default(0)
  image_url  String? 
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  productId Int
  product   Product @relation(fields: [productId], references: [id])

  orderDetails OrderDetail[]

  @@map("product_variant")
}

model ProductQuestion {
  id        Int      @id @default(autoincrement())
  content   String   @db.VarChar(5000)
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  productId Int
  product   Product @relation(fields: [productId], references: [id])

  userId Int
  user   User @relation(fields: [userId], references: [id])

  answers ProductAnswer[]

  @@map("product_question")
}

model ProductAnswer {
  id        Int      @id @default(autoincrement())
  content   String   @db.VarChar(5000)
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  questionId Int
  productQuestion   ProductQuestion @relation(fields: [questionId], references: [id])

  userId Int
  user   User @relation(fields: [userId], references: [id])

  @@map("product_answer")
}

model ProductReview {
  id        Int      @id @default(autoincrement())
  rating    Int
  content   String   @db.VarChar(5000)
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  productId Int
  product   Product @relation(fields: [productId], references: [id])

  userId Int
  user   User @relation(fields: [userId], references: [id])

  image_reviews ImageReview[]

  @@map("product_review")
}

model ImageReview {
  id        Int      @id @default(autoincrement())
  url       String   
  alt       String
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  reviewId Int
  review   ProductReview @relation(fields: [reviewId], references: [id])

  @@map("image_review")
}

model Order {
  id             Int      @id @default(autoincrement())
  discount_total Decimal @db.Decimal(12, 2)
  delivery_cost  Decimal @db.Decimal(12, 2)
  grand_total    Decimal @db.Decimal(12, 2)
  payment_method String
  status         String
  created_at      DateTime @default(now())
  updated_at      DateTime @updatedAt

  userId Int
  user   User @relation(fields: [userId], references: [id])

  promotionId Int?
  promotion   Promotion? @relation(fields: [promotionId], references: [id])

  orderDetails OrderDetail[]

  @@map("order")
}

model Promotion {
  id               Int      @id @default(autoincrement())
  name             String
  code             String   @unique
  discount         Decimal @db.Decimal(12, 2)
  discount_type    String   @default("PERCENT") //PERCENT, FLAT
  start_date       DateTime 
  end_date         DateTime 
  min_order        Decimal @db.Decimal(12, 2)
  status           Boolean  @default(true)   
  created_at        DateTime @default(now())
  updated_at        DateTime @updatedAt

  orders Order[]

  @@map("promotion")
}
model OrderDetail {
  id             Int      @id @default(autoincrement())
  price          Decimal @db.Decimal(12, 2)
  quantity       Int   @default(0)
  subtotal       Decimal @db.Decimal(12, 2)
  
  orderId         Int
  order           Order @relation(fields: [orderId], references: [id])

  variantId      Int
  variant        ProductVariant @relation(fields: [variantId], references: [id])
  created_at      DateTime @default(now())
  updated_at      DateTime @updatedAt

  @@map("order_detail")
}

// Enum cho các bảng
enum ProductStatus {
  ACTIVE
  OUT_OF_STOCK
  HIDDEN
  COMING_SOON
}
