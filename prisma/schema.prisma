// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model Product {
  id          Int           @id @default(autoincrement())
  name        String
  slug        String        @unique
  description String?       @db.VarChar(1000)
  content     String?       @db.VarChar(5000)
  image_url   String?
  brand       String
  stock       Int           @default(0)
  status      ProductStatus @default(ACTIVE)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  categoryId Int
  category   Category @relation(fields: [categoryId], references: [id])

  tags     Tags[]
  images   Image[]
  wishlist Wishlist[]
  comments Comment[]
  variants ProductVariant[]

  @@map("product")
}

model Category {
  id        Int      @id @default(autoincrement())
  name      String
  slug      String   @unique
  image_url String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  products Product[]

  @@map("category")
}

model Tags {
  id        Int      @id @default(autoincrement())
  name      String
  slug      String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  products Product[]

  @@map("tags")
}

model Image {
  id        Int      @id @default(autoincrement())
  url       String
  alt       String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  productId Int
  product   Product @relation(fields: [productId], references: [id])

  @@map("image")
}

model Wishlist {
  id        Int      @id @default(autoincrement())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  productId Int
  product   Product @relation(fields: [productId], references: [id])

  userId Int
  user   User @relation(fields: [userId], references: [id])

  @@map("wishlist")
}

model User {
  id        Int      @id @default(autoincrement())
  name      String
  email     String   @unique
  password  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  roleId Int
  role   Role @relation(fields: [roleId], references: [id])

  wishlist Wishlist[]
  comments Comment[]

  @@map("user")
}

model Role {
  id        Int      @id @default(autoincrement())
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users User[]

  @@map("role")
}

model Comment {
  id        Int      @id @default(autoincrement())
  content   String   @db.VarChar(2500)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  productId Int
  product   Product @relation(fields: [productId], references: [id])

  userId Int
  user   User @relation(fields: [userId], references: [id])

  @@map("comment")
}

model ProductVariant {
  id        Int     @id @default(autoincrement())
  storage   String  
  color     String  
  condition String?  
  price     Decimal @db.Decimal(12, 2) 
  stock     Int     @default(0)
  imageUrl  String? 
  createdAt DateTime @default(now())
  updatedAt DateTime?

  productId Int
  product   Product @relation(fields: [productId], references: [id])

  @@map("product_variant")
}

model ProductQuestion {
  id        Int      @id @default(autoincrement())
  content   String   @db.VarChar(5000)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  productId Int
  product   Product @relation(fields: [productId], references: [id])

  userId Int
  user   User @relation(fields: [userId], references: [id])

  @@map("product_question")
}

model ProductAnswer {
  id        Int      @id @default(autoincrement())
  content   String   @db.VarChar(5000)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  questionId Int
  productQuestion   ProductQuestion @relation(fields: [questionId], references: [id])

  userId Int
  user   User @relation(fields: [userId], references: [id])

  @@map("product_answer")
}

// Enum cho các bảng
enum ProductStatus {
  ACTIVE
  OUT_OF_STOCK
  HIDDEN
  COMING_SOON
}
